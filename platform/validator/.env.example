# Minotaur Subnet 112 — validator stack configuration
#
# Copy this file to .env, fill in YOUR_* placeholders, then:
#   docker compose --profile autoupdate up -d    # with Watchtower auto-update
#   docker compose up -d                          # without (manual pulls)
#
# Anything left at YOUR_* will break the stack at startup. The other
# values have sensible defaults baked into docker-compose.yml and can
# be overridden here only if you need something non-standard.

# ── Image tag ───────────────────────────────────────────────────────
# Defaults to `:stable` — the subnet team manually promotes a new SHA
# to :stable after it has soaked on our prod. Pinning to a specific
# SHA (e.g. `sha-abc1234`) lets you opt out of auto-update entirely.
# MINOTAUR_IMAGE_TAG=stable

# ── Bittensor identity ──────────────────────────────────────────────
# The wallet + hotkey you registered with `btcli subnet register --netuid 112`.
# These names match what btcli created at ~/.bittensor/wallets/<WALLET_NAME>/hotkeys/<HOTKEY_NAME>.
WALLET_NAME=YOUR_WALLET_NAME
HOTKEY_NAME=YOUR_HOTKEY_NAME

# Where btcli stored your wallets on this host. Mounted read-only into
# the validator container.
#
# ── SECURITY: keep your coldkey OUT of the mounted directory ──────────
# The :ro mount stops the container from MODIFYING your keys, but the
# coldkey file is still READABLE inside the container. An RCE in the
# api or validator process would let an attacker exfiltrate it.
#
# Recommended setup — mount ONLY the hotkey:
#   mkdir -p /opt/bt-hotkey-only/$WALLET_NAME/hotkeys
#   cp ~/.bittensor/wallets/$WALLET_NAME/hotkeys/$HOTKEY_NAME \
#      /opt/bt-hotkey-only/$WALLET_NAME/hotkeys/
#   chown -R 1000:1000 /opt/bt-hotkey-only      # uid 1000 is the
#                                              #  non-root container user
#   chmod -R 600 /opt/bt-hotkey-only/$WALLET_NAME/hotkeys
#   BITTENSOR_WALLET_PATH=/opt/bt-hotkey-only
#
# IMPORTANT: as of 2026-05-26 the validator image runs as uid 1000
# (audit C5 — non-root runtime). The host-side wallet directory must be
# READABLE BY uid 1000. If you used the default ${HOME}/.bittensor/
# wallets, your existing ownership (likely your shell user) probably
# already works — but a freshly-mounted directory owned by root with
# 700 perms won't. Common fixes:
#     chown -R 1000:1000 <wallet-dir>          # cleanest
#     chmod -R o+rX <wallet-dir>               # if you can't chown
# The mount inside the container is /home/minotaur/.bittensor/wallets
# (was /root/.bittensor/wallets prior to the uid 1000 migration).
#
# Keep your coldkey in a separate directory that is NEVER mounted into
# Docker. Use it offline (different machine, hardware wallet, etc.)
# for stake/unstake operations only.
# BITTENSOR_WALLET_PATH=/path/to/.bittensor/wallets

# ── Network endpoints ───────────────────────────────────────────────
# Bittensor finney chain (metagraph). The default `finney` alias resolves
# to the public `wss://entrypoint-finney.opentensor.ai:443` endpoint,
# which is rate-limited per source IP — fine for a home/single-IP setup,
# but operators sharing egress IPs (datacenter colos) often hit the cap
# even at low validator load.
#
# If you already run your own subtensor node, point SUBTENSOR_URL at it
# instead. The same node also serves the BT EVM JSON-RPC on the same
# port — see BITTENSOR_EVM_UPSTREAM_RPC_URL below for the matching EVM
# override. See docs/validator/quickstart.md ("Run your own subtensor")
# for the node-side flags you need.
#
# SUBTENSOR_URL=finney
# SUBTENSOR_URL=ws://your-subtensor-host:9944       # self-hosted (preferred for DC operators)
# NETUID=112

# Public URL where this validator serves /identity, used by other
# validators for peer discovery. Must be reachable from the public
# internet on port 9100.
#
# Examples:
#   http://your-static-ip:9100
#   http://validator.example.com:9100
VALIDATOR_AXON_URL=http://YOUR_PUBLIC_HOST:9100

# ── EVM consensus signing key ───────────────────────────────────────
# Used to sign EIP-712 order-consensus approvals. Does NOT need to
# hold any funds. Generate a fresh one if you don't have one:
#   cast wallet new
# Hex-encoded with 0x prefix. KEEP THIS SECRET.
VALIDATOR_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY

# ── On-chain contract addresses ─────────────────────────────────────
# Current values from docs/operator/network-reference.md (2026-05-21
# post-quorum-refactor stack). If you see startup errors about
# "quorumBps() reverted" you're pointing at a stale address — re-check
# the network reference page.

# Base (chain 8453)
VALIDATOR_REGISTRY_8453=0x88a08d1105393EACE9B6f5ff678DbE508B8639aC
APP_REGISTRY_8453=0x0B5fE44e90515571761D86C28c4855F325EDE098

# BT EVM (chain 964)
VALIDATOR_REGISTRY_964=0x0B5fE44e90515571761D86C28c4855F325EDE098
APP_REGISTRY_964=0x80758D3Bf11715c82dB9964C634d5Fd8a0C58aBF
CHAMPION_REGISTRY_964=0x33105027d03e76bf1F3679C0CB9b2688da383fb3

# ── Upstream RPCs for Anvil forks ───────────────────────────────────
# Anvil restarts re-fork from these URLs. Public endpoints are
# rate-limited; use your own Alchemy/Infura keys for production.
#
# Ethereum mainnet — REQUIRED. No reliable public archive.
ETH_UPSTREAM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Base mainnet — REQUIRED. Use Alchemy/Infura/QuickNode.
BASE_UPSTREAM_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# BT EVM — public endpoint works for a single home-IP validator. In
# shared-IP / datacenter setups the per-IP rate limit on
# lite.chain.opentensor.ai is often eaten by neighbors before your own
# traffic lands.
#
# If you run your own subtensor node (recommended), the SAME node serves
# the BT EVM JSON-RPC on its substrate RPC port — no extra binary, no
# extra port. Point this at it and the Anvil-BTEVM fork will pull state
# from your own node instead of the public endpoint. Use `http://` for
# Anvil's --fork-url (it does HTTP polling, not WS).
#
# BITTENSOR_EVM_UPSTREAM_RPC_URL=https://lite.chain.opentensor.ai
# BITTENSOR_EVM_UPSTREAM_RPC_URL=http://your-subtensor-host:9944       # self-hosted

# ── Consensus tunables (optional overrides) ─────────────────────────
# Force followers to re-simulate proposals on Anvil (1) instead of
# JS-only rescoring (0). Default is 1 — full independent verification.
# Set to 0 if your hardware can't keep up with re-simulation load.
# FOLLOWER_PROPOSAL_RESIMULATE=1

# Score threshold (matches network norm — leave at default)
# SCORE_THRESHOLD=5000

# ── App catalog sync ────────────────────────────────────────────────
# Base URL of the leader's API. The validator daemon polls
# /v1/apps/ + /v1/apps/{id}/status from here on a 60s tick and writes
# every AppIntentDefinition (including js_code) and DeploymentResult
# into its local store, so the JsExecutionEngine can re-score incoming
# consensus proposals. Required for every third-party validator;
# leaders should leave this unset.
#
# Trust note: js_code is fetched and trusted as-is — there is no
# on-chain hash anchor at this layer. A compromised leader could push
# malicious JS to followers. Tracked follow-up: AppRegistry JS hash
# anchoring. The daemon logs a SECURITY NOTICE on startup whenever
# this is set.
LEADER_API_URL=https://api.minotaursubnet.com

# ── Internal-only envs — DO NOT SET ─────────────────────────────────
# ORDER_CONSENSUS_PEERS and CHAMPION_CONSENSUS_PEERS are pinned-peer
# escape hatches used by the subnet team's own production deployment,
# where the metagraph axon URLs aren't published yet. Third-party
# validators should ALWAYS leave these unset — the daemon's automatic
# peer discovery via the Bittensor metagraph + on-chain ValidatorRegistry
# is the supported path. Setting these as a third party bypasses
# discovery and pins to a stale set that won't include the rest of the
# network.

# ── Relayer (optional override) ─────────────────────────────────────
# Singleton transaction submitter run by the subnet team. Third-party
# validators do NOT hold a gas wallet — the api signs an EIP-191
# freshness wrapper around each quorum bundle (using your
# VALIDATOR_PRIVATE_KEY above) and POSTs to this URL; the relayer
# verifies the wrapper signer is registered on-chain, then pays the
# gas to submit. Defaults to the public production endpoint; override
# only for local-testnet or if you're testing against a private relayer.
# RELAYER_URL=https://relayer.minotaursubnet.com

# ── Admin API key (REQUIRED) ────────────────────────────────────────
# Gates POST /v1/apps/, POST /v1/apps/{id}/deploy, PUT /v1/apps/{id}/scoring,
# POST /v1/wallets/, and a handful of debug routes behind an X-Admin-Key
# header.
#
# REQUIRED on every third-party validator. The default `RELAYER_URL` above
# points at the subnet team's relayer, which accepts every deploy request
# that's wrapper-signed by a key in the on-chain ValidatorRegistry — i.e.
# YOUR `VALIDATOR_PRIVATE_KEY`. Without ADMIN_API_KEY set, any anonymous
# internet caller can POST /v1/apps/{id}/deploy to your api and the
# relayer will pay gas for arbitrary contract deploys until its daily
# cap is exhausted.
#
# Generate with:
#   openssl rand -hex 32
# Keep it private. `docker compose up` will fail fast if this is unset.
ADMIN_API_KEY=YOUR_RANDOM_HEX_STRING

# ── Champion-consensus proposal gate (REQUIRED) ─────────────────────
# Shared HMAC-style secret the leader presents as an Authorization:
# Bearer header on every POST /v1/solver/round/consensus/proposal call.
# Without it, anonymous callers can trigger Docker container spawn via
# the docker-socket-proxy on attacker-named images.
#
# Generate with:
#   openssl rand -hex 32
# Send the value to the subnet team at validator registration time so
# they can configure the leader to authenticate to you. `docker compose
# up` will fail fast if this is unset.
SOLVER_ROUND_INTERNAL_API_KEY=YOUR_RANDOM_HEX_STRING

# ── Defense-in-depth consensus toggles (default-on) ─────────────────
# Both default to 1; override only if you understand the implications.
#
# CONSENSUS_REQUIRE_SIGNED_CHAMPION_PROPOSALS=1
#   Reject champion proposals without a valid EIP-191 signature
#   recovered against the on-chain ValidatorRegistry.
#
# CONSENSUS_ENFORCE_ONCHAIN_REGISTRY=1
#   On every proposal, re-check the proposer against the on-chain
#   ValidatorRegistry (not just the in-memory peer cache, which can be
#   stale by up to 300s after a slash/removal).
# CONSENSUS_REQUIRE_SIGNED_CHAMPION_PROPOSALS=1
# CONSENSUS_ENFORCE_ONCHAIN_REGISTRY=1
