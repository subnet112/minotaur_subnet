# .env.leader.example — leader-only overrides for the unified docker-compose.yml
# =============================================================================
# The tracked compose ships FOLLOWER-SAFE defaults (each equals the code default,
# verified against the source). A follower needs NONE of this file. The LEADER
# restores its real behavior with these overrides — copy to `.env` on the leader
# (dc.sh merges it with the secrets in .env.keys).
#
# WITHOUT these, a leader started from the unified compose would silently regress:
# provenance enforcement OFF, no candidate-image push, live champion on
# --network=none, unbounded submission store, proxy headers untrusted, etc.
#
# Infra endpoints and all secrets are PLACEHOLDERS — fill them from the vault /
# .env.keys. Never commit real endpoints, IPs, tokens, or keys.

# --- role selection -------------------------------------------------------
# NOTE: no `autoupdate` — the leader deploys via the update.sh cron, NOT watchtower.
COMPOSE_PROFILES=leader,benchmark-worker
ENABLE_SOLVER_ROUND_COORDINATOR=1        # api runs the round coordinator
ENABLE_BENCHMARK_WORKER=1                 # hand the slate to the benchmark-worker profile
SUBMISSIONS_ACCEPTING=1                   # leader accepts user submissions (compose default 0)
ENABLE_DEX_COMPARE=1                      # DEX-aggregator comparison (compose default 0)
RELAYER_URL=http://relayer:8091          # use the LOCAL relayer container (default: public relayer)

# --- round lifecycle ------------------------------------------------------
SOLVER_ROUND_OPEN_SECONDS=1200           # 20-min open window (compose default 300)
SUBMISSIONS_MAX_RECORDS=5000             # store retention cap (compose default 0 = unbounded)
SUBMISSIONS_MAX_ROUNDS_PER_FINGERPRINT=0 # leader disables the per-fingerprint round cap (default 2)
ROUND_ANCHOR_SHADOW=1

# --- provenance enforcement (leader-only; =1 REQUIRES the signer list below) --
REQUIRE_SIGNED_PROVENANCE=1
REQUIRE_ASYMMETRIC_PROVENANCE=1
SUBMISSION_PROVENANCE_ALLOWED_SIGNERS=<REDACTED — allowed provenance signer set>

# --- champion / live solver ----------------------------------------------
LIVE_SOLVER_NETWORK=production_minotaur   # live champion serves on the real docker net (default: --network=none)
CANDIDATE_IMAGE_REPO=ghcr.io/subnet112/minotaur-solver  # non-empty ⇒ leader pushes candidate digests
EMISSION_TIME_WEIGHTED_OBSERVE=1          # observe-only time-weighted emission soak
CHAMPION_CONSENSUS_TIMEOUT_SECONDS=120    # (code default 30)

# --- ingress / perf -------------------------------------------------------
TRUST_PROXY_HEADERS=1                     # api behind nginx — honor X-Forwarded-For
RPC_PROXY_PIN_CACHE_MAX_BLOCKS=32         # (code default 4)
RPC_PROXY_PIN_CACHE_PERSIST_PATH=/var/cache/pin-proxy/snapshot.json
RELAYER_MIN_BALANCE_WEI=1000000000000000  # 0.001 (embedded-relayer path; api uses HttpRelayer)

# --- image tag + host bind-mount paths (compose defaults are follower-safe) --
MINOTAUR_IMAGE_TAG=latest                     # leader tracks :latest (compose default :stable)
BITTENSOR_WALLET_PATH=/home/ubuntu/minotaur/wallets     # compose default ${HOME}/.bittensor/wallets
SOLVER_REPO_HOST_PATH=/home/ubuntu/minotaur-solver      # host solver-repo checkout → /solver-repo
GHCR_DOCKER_CONFIG_DIR=/home/ubuntu/minotaur/.ghcr-docker  # GHCR push creds → /home/minotaur/.docker

# --- screening / registries -----------------------------------------------
SOLVER_REPO_PATH=/solver-repo
SUBMISSION_GIT_CLONE_USERNAME=x-access-token   # GitHub token-auth username (not a secret)
ALLOW_ADMIN_SOLVER_REPO_TOKEN=1
STAGE3_DISABLED=1                              # leader disables Stage-3 regression (compose default 0)
APP_REGISTRY_1=0xbA70eA9857c3813A694f6CA71Fa98eA6E584dF1B        # ETH-mainnet AppRegistry (public)
VALIDATOR_REGISTRY_1=0x694F0a95D3105EcC2ad86FcaFAa1A4467F1852A6  # ETH-mainnet ValidatorRegistry (public)
# Identity (public ss58, but validator-specific — fill per deployment):
VALIDATOR_HOTKEY_SS58=<this validator's hotkey ss58>
SUBNET_OWNER_HOTKEY=<subnet owner hotkey ss58>

# --- infra endpoints (PLACEHOLDERS — fill per environment) ----------------
API_URL=http://<leader-host>:8080
COW_BASE_URL=<cow-onchain proxy base url>
DEX_COMPARE_SOURCE=cow_onchain
DEX_COMPARE_CHAINS=1,8453
DEX_COMPARE_COW_APP_ID=<chain:app_id pairs>
ORDER_CONSENSUS_PEERS=<order-consensus peer list>
# LEADER_API_URL is a FOLLOWER-oriented var (followers point at the leader). Its
# compose default is the public https://api.minotaursubnet.com — self-referential
# on the leader's own validator. Point it local (or leave empty if unused on the leader):
LEADER_API_URL=http://api:8080

# --- secrets: set in .env.keys, NOT here ----------------------------------
# RELAYER_PRIVATE_KEY, VALIDATOR_PRIVATE_KEY, VALIDATOR_ADDRESSES, ADMIN_API_KEY,
# SOLVER_ROUND_INTERNAL_API_KEY, SOLVER_REPO_TOKEN, SUBMISSION_GIT_CLONE_PASSWORD,
# BITTENSOR_EVM_RELAYER_RPC_URL  (the relayer's BT-EVM RPC — carries an auth token)

# =============================================================================
# The structural gaps a `docker compose config` diff vs the live
# docker-compose.production.yml surfaced are now handled IN the compose:
#   - image tag → ${MINOTAUR_IMAGE_TAG:-stable}   (set MINOTAUR_IMAGE_TAG=latest above)
#   - wallet path → ${BITTENSOR_WALLET_PATH:-...}  (set above)
#   - leader-only api mounts /solver-repo + /home/minotaur/.docker → parameterized
#     (followers mount empty .leader-mounts/* placeholders; leader sets the host paths above)
#   - validator store-data:/data → added
#   - the ~14 box-only env vars → added to api/worker/validator as ${VAR:-<code-default>}
# Verify with:  COMPOSE_PROFILES=leader,benchmark-worker docker compose \
#   -f docker-compose.yml --env-file .env --env-file .env.keys config
# then diff that against the box's live render — the only differences should be the
# intended overrides in this file.
#
# NOTE: the leader also GAINS a few vars the (older) box compose lacked but the
# current follower compose carries — mostly benign (empty, local container URLs,
# code defaults). Two to CONFIRM are intended fleet-consistency (the leader runs
# :latest code, which expects them): CONSENSUS_ENFORCE_ONCHAIN_REGISTRY=1,
# CONSENSUS_REQUIRE_SIGNED_CHAMPION_PROPOSALS=1, CONSENSUS_MODE=real.
# =============================================================================
