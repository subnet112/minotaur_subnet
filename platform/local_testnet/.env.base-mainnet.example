# ──────────────────────────────────────────────────────────────────────────────
# Base Mainnet Configuration
#
# Copy to .env.base-mainnet and fill in real values.
# Generate wallets with: bash generate-base-wallets.sh
# ──────────────────────────────────────────────────────────────────────────────

# Base mainnet RPC (Alchemy, Infura, or other provider)
BASE_MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Relayer wallet — fund with ~0.01 ETH on Base for gas
BASE_RELAYER_PRIVATE_KEY=0x...

# Validator signing keys (3 validators for 2-of-3 quorum)
BASE_VALIDATOR_KEY_0=0x...
BASE_VALIDATOR_KEY_1=0x...
BASE_VALIDATOR_KEY_2=0x...

# Comma-separated validator addresses (derived from keys above)
BASE_VALIDATOR_ADDRESSES=0xAddr0,0xAddr1,0xAddr2

# Relayer transaction timeout (seconds) — Base blocks are ~2s
RELAYER_RECEIPT_TIMEOUT=60

# Consensus peer addresses (format: addr@url,addr@url,addr@url)
# These reference the validator addresses derived from the keys above.
# ORDER_CONSENSUS_PEERS: validator services that re-simulate proposals
# API_CLUSTER_PEERS: API peers for champion consensus
# BASE_ORDER_CONSENSUS_PEERS=0xAddr0@http://validator:9100,0xAddr1@http://validator-peer-1:9100,0xAddr2@http://validator-peer-2:9100
# BASE_API_CLUSTER_PEERS=0xAddr1@http://api-peer-1:8080,0xAddr2@http://api-peer-2:8080

# Optional: Finney subtensor for real TAO balance queries / bridging
# BASE_SUBTENSOR_URL=wss://entrypoint-finney.opentensor.ai:443
# ENABLE_NATIVE_BITTENSOR_PROXY=1
# NATIVE_BITTENSOR_NETWORK=finney
