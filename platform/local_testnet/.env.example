# ──────────────────────────────────────────────────────────────────────
# Anvil deterministic test keys
#
# These are PUBLIC keys derived from the well-known Foundry test
# mnemonic ("test test test test test test test test test test test
# junk"). They print on every `anvil` boot and hold 10,000 ETH on every
# anvil instance — they are SAFE for local_testnet use and UNSAFE
# anywhere else. NEVER fund these addresses on a real chain.
#
# Override below if you want to run the local stack with your own keys.
# ──────────────────────────────────────────────────────────────────────

# Anvil account #0 — deployer + relayer in the local stack
ANVIL_RELAYER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Validator quorum keys (Anvil accounts #2, #1, #3 respectively).
VALIDATOR_KEY_0=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
VALIDATOR_KEY_1=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
VALIDATOR_KEY_2=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6

# Required: Alchemy/Infura URL for Anvil mainnet fork
# Get a free key at https://www.alchemy.com/
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Required: Alchemy URL for Base mainnet fork (same API key works)
BASE_ALCHEMY_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optional overrides
# BLOCK_TIME=2
# QUORUM_BPS=8000
# SCORE_THRESHOLD=5000

# Optional host port overrides if your machine already uses the defaults.
# HOST_FRONTEND_PORT=14000
# HOST_API_PORT=18080
# HOST_RELAYER_PORT=18091
# HOST_ANVIL_ETH_PORT=18545
# HOST_ANVIL_BASE_PORT=18546
# HOST_SUBTENSOR_WS_PORT=19944
# HOST_SUBTENSOR_RPC_PORT=19945
# HOST_LIT_BRIDGE_PORT=13100

# Local demo safety defaults
MVP_DEMO_MODE=1
ENABLE_NATIVE_BITTENSOR_PROXY=0

# Optional local-only native Bittensor demo override.
# Leave this unset unless you are intentionally testing the native proxy path
# against the local Docker subtensor started by this stack.
# NATIVE_BITTENSOR_NETWORK=ws://subtensor:9944


# Order execution consensus mode:
#   "local" (default) = auto-sign with all validator keys (fast, no peer comms)
#   "real"            = broadcast to validator peers for independent re-simulation
# CONSENSUS_MODE=local
# ORDER_CONSENSUS_QUORUM_BPS=6666

# Solver repo for champion merge (relayer merges winning branch → main).
# SOLVER_REPO_PATH: local clone path (must be mounted in the API container)
# SOLVER_REPO_URL: GitHub URL (for HTTPS auth rewrite)
# SOLVER_REPO_TOKEN: fine-grained PAT with Contents (read/write) on the solver repo
# SOLVER_REPO_PATH=/solver-repo
# SOLVER_REPO_URL=https://github.com/subnet112/minotaur-solver.git
# SOLVER_REPO_TOKEN=github_pat_your_fine_grained_token

# Optional private solver repo demo support for the API screening service.
# Use a dedicated read-only repo credential, not a miner account credential.
# Prefer a fine-grained GitHub token scoped to only the private solver repo.
# SUBMISSION_ALLOWED_REPO_HOSTS=github.com
# SUBMISSION_GIT_CLONE_ALLOWED_HOSTS=github.com
# SUBMISSION_GIT_CLONE_USERNAME=x-access-token
# SUBMISSION_GIT_CLONE_PASSWORD=github_pat_your_read_only_token
